# This is one single shared deployment serving every client -- GHL
# credentials (Location ID, Private Integration Token, Calendar, Pipeline)
# are NOT set here. They live in Supabase's `clients` table and are managed
# live through the Admin portal, resolved per-request based on who's logged
# in. There is nothing GHL-specific to configure in this file.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key is safe to expose to the browser; used only for the login pages.
SUPABASE_ANON_KEY=

# --- App ---
PORT=3000
SESSION_SECRET=change-me
# Public base URL of this deployment -- used to build the invite email's
# redirect link to set-password.html. Must also be added to Supabase's
# Auth > URL Configuration > Redirect URLs allowlist.
APP_BASE_URL=http://localhost:3000
# Product name shown everywhere in the UI -- changes per agency reselling
# this portal, without needing a code change.
BRAND_NAME=Archie AI
